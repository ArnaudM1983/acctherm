---
import '../styles/global.css';

const { title, description, schema } = Astro.props;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Injection dynamique du Schema.org sans injection de script malveillant -->
    {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />}
  </head>
  <body class="bg-[#f8fafc] text-slate-700 font-inter antialiased">
    <div class="min-h-screen flex flex-col selection:bg-primary-orange/30">
      <slot />
    </div>
  </body>
</html>