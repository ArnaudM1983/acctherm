---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FAQ from "../../components/FAQ.astro";
import Contact from "../../components/Contact.astro";
import { Icon } from 'astro-icon/components';

const pageTitle = "Attestation de Fin de Chantier RE2020 Lyon | Cerfa DAACT";
const pageDescription = "Génération de votre attestation finale de conformité RE2020 à Lyon et en Rhône-Alpes. Sécurisez votre dépôt de DAACT en mairie sous 24h.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Génération de l'attestation de fin de chantier RE2020",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://acctherm.com/#localbusiness"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Auvergne-Rhône-Alpes",
        "sameAs": "https://www.wikidata.org/wiki/Q18247094"
      },
      "description": "Délivrance de l'attestation réglementaire Cerfa de conformité environnementale et thermique à l'achèvement des travaux pour dépôt du permis de construire."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://acctherm.com" },
        { "@type": "ListItem", "position": 2, "name": "Prestations", "item": "https://acctherm.com/prestations" },
        { "@type": "ListItem", "position": 3, "name": "Attestation de fin de chantier", "item": "https://acctherm.com/prestations/attestation-fin-de-chantier" }
      ]
    }
  ]
};

const attestationFaqs = [
  {
    question: "Qu'est-ce que l'attestation de fin de chantier RE2020 ?",
    answer: "C'est un document Cerfa officiel et obligatoire qui certifie que votre construction respecte toutes les exigences de la réglementation environnementale RE2020 (ou RT2012). Elle doit être jointe obligatoirement à votre Déclaration Attestant l'Achèvement et la Conformité des Travaux (DAACT) adressée à votre mairie."
  },
  {
    question: "Qui est habilité à générer cette attestation de conformité ?",
    answer: "La loi encadre strictement la délivrance de ce document. Il peut être établi par un contrôleur technique, un architecte, un organisme de certification, ou un diagnostiqueur agréé pour le DPE. ACCTHERM prend en charge la vérification sur site et l'édition de ce document officiel."
  },
  {
    question: "Quelles pièces techniques sont nécessaires pour l'établir ?",
    answer: "Pour générer l'attestation finale, nous devons nous appuyer sur l'étude thermique complète du projet (fichier XML/RSET), le rapport officiel de mesure d'infiltrométrie finale validé, ainsi que le rapport de conformité du système de ventilation (protocole Promevent)."
  }
];
---

<Layout title={pageTitle} description={pageDescription} schema={serviceSchema}>
  <Header />
  
  <main class="grow bg-[#f8fafc]">
    
    <section class="w-full bg-white border-b border-slate-100 relative overflow-hidden pt-12 pb-16 md:py-24">
      <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-xs font-semibold text-slate-400 mb-6">
          <a href="/" class="hover:text-primary-orange transition-colors">Accueil</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <a href="/prestations" class="hover:text-primary-orange transition-colors">Prestations</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <span class="text-slate-600" aria-current="page">Attestation fin de chantier</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7 text-left">
            <span class="inline-block bg-orange-100 text-primary-orange text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg mb-6">
              Clôture Juridique du Permis de Construire
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-black font-display text-primary-navy leading-[1.1] mb-6 tracking-tight">
              Attestation de Fin de Chantier RE2020 <span class="text-primary-orange">à Lyon</span>
            </h1>
            <p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed font-medium max-w-2xl">
              Obtenez le feu vert administratif pour votre nouvelle construction. Nous assurons le contrôle final sur site et la génération de votre <strong class="text-primary-navy font-bold">attestation réglementaire Cerfa</strong> sous 24h pour déclarer la conformité de vos travaux en mairie sans encombre.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contact" class="bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all shadow-lg shadow-orange-200 text-center cursor-pointer flex items-center justify-center gap-2">
                <Icon name="lucide:file-text" class="w-4 h-4" /> Demander mon attestation Cerfa
              </a>
            </div>
          </div>
          
          <div class="lg:col-span-5 bg-slate-50 border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
            <h3 class="text-sm font-bold text-primary-navy uppercase tracking-wider mb-4 flex items-center gap-2">
              <Icon name="lucide:shield-check" class="text-primary-orange w-4 h-4" /> Clôture administrative sécurisée
            </h3>
            <p class="text-xs text-slate-500 font-medium mb-4">L'étape finale indispensable pour officialiser la conformité thermique et environnementale de votre maison individuelle.</p>
            <ul class="space-y-3 text-xs md:text-sm font-semibold text-slate-600">
              <li class="flex items-center gap-2.5 py-1.5 border-b border-slate-200/60">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Vérification de la cohérence de l'étude RSET
              </li>
              <li class="flex items-center gap-2.5 py-1.5 border-b border-slate-200/60">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Intégration des rapports Infiltrométrie & VMC
              </li>
              <li class="flex items-center gap-2.5">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Édition du document Cerfa officiel pour votre DAACT
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <FAQ title="Questions fréquentes sur l'attestation Cerfa" faqs={attestationFaqs} />
    <Contact />
  </main>
  <Footer />
</Layout>