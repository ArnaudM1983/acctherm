---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FAQ from "../../components/FAQ.astro";
import Contact from "../../components/Contact.astro";
import { Icon } from 'astro-icon/components';

const pageTitle = "Attestation de Fin de Chantier RE2020 Lyon | Cerfa DAACT";
const pageDescription = "Génération de votre attestation finale de conformité RE2020 à Lyon et en Rhône-Alpes. Sécurisez votre dépôt de DAACT en mairie sous 24h.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Génération de l'attestation de fin de chantier RE2020",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://acctherm.com/#localbusiness"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Auvergne-Rhône-Alpes",
        "sameAs": "https://www.wikidata.org/wiki/Q18247094"
      },
      "description": "Délivrance de l'attestation réglementaire Cerfa de conformité environnementale et thermique à l'achèvement des travaux pour dépôt du permis de construire."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://acctherm.com" },
        { "@type": "ListItem", "position": 2, "name": "Prestations", "item": "https://acctherm.com/prestations" },
        { "@type": "ListItem", "position": 3, "name": "Attestation de fin de chantier", "item": "https://acctherm.com/prestations/attestation-fin-de-chantier" }
      ]
    }
  ]
};

const attestationFaqs = [
  {
    question: "Qu'est-ce que l'attestation de fin de chantier RE2020 ?",
    answer: "C'est un document Cerfa officiel et obligatoire qui certifie que votre construction respecte toutes les exigences de la réglementation environnementale RE2020 (ou RT2012). Elle doit être jointe obligatoirement à votre Déclaration Attestant l'Achèvement et la Conformité des Travaux (DAACT) adressée à votre mairie."
  },
  {
    question: "Qui est habilité à générer cette attestation de conformité ?",
    answer: "La loi encadre strictement la délivrance de ce document. Il peut être établi par un contrôleur technique, un architecte, un organisme de certification, ou un diagnostiqueur agréé. ACCTHERM prend en charge la vérification des données sur site et l'édition de ce document officiel."
  },
  {
    question: "Quelles pièces techniques sont nécessaires pour l'établir ?",
    answer: "Pour générer l'attestation finale, nous devons nous appuyer sur l'étude thermique complète du projet (fichier XML/RSET), le rapport officiel de mesure d'infiltrométrie finale validé, ainsi que le rapport de conformité du système de ventilation (protocole Promevent)."
  }
];
---

<Layout title={pageTitle} description={pageDescription} schema={serviceSchema}>
  <Header />
  
  <main class="grow bg-[#f8fafc]">
    
    <!-- 1. HERO SECTION SÉMANTIQUE -->
    <section class="w-full bg-white border-b border-slate-100 relative overflow-hidden pt-16 pb-16">
      <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <!-- BREADCRUMB -->
        <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-xs font-semibold text-slate-400 mb-6">
          <a href="/" class="hover:text-primary-orange transition-colors flex items-center gap-1">Accueil</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <a href="/prestations" class="hover:text-primary-orange transition-colors">Prestations</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <span class="text-slate-600" aria-current="page">Attestation fin de chantier</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7 text-left">
            <span class="inline-block bg-orange-100 text-primary-orange text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg mb-6">
              Clôture Juridique du Permis de Construire
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-black font-display text-primary-navy leading-[1.1] mb-6 tracking-tight">
              Attestation de Fin de Chantier RE2020 <span class="text-primary-orange">à Lyon</span>
            </h1>
            <p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed font-medium max-w-2xl">
              Obtenez le feu vert administratif pour votre nouvelle construction. Nous assurons le contrôle final sur site et la génération de votre <strong class="text-primary-navy font-bold">attestation réglementaire Cerfa</strong> sous 24h pour déclarer la conformité de vos travaux en mairie sans encombre.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contact" class="bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all shadow-lg shadow-orange-200 text-center cursor-pointer flex items-center justify-center gap-2">
                <Icon name="lucide:file-text" class="w-4 h-4" /> Demander mon attestation Cerfa
              </a>
              <a href="#pourquoi" class="border-2 border-primary-navy text-primary-navy font-bold py-4 px-8 rounded-xl text-sm hover:bg-primary-navy hover:text-white transition-all text-center cursor-pointer">
                Pourquoi sécuriser cette étape ?
              </a>
            </div>
          </div>
          
          <!-- Encart technique visuel de droite -->
          <div class="lg:col-span-5 bg-slate-50 border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
            <h3 class="text-sm font-bold text-primary-navy uppercase tracking-wider mb-4 flex items-center gap-2">
              <Icon name="lucide:sliders" class="text-primary-orange w-4 h-4" /> Fiche Technique du Document
            </h3>
            <ul class="space-y-3.5 text-xs md:text-sm font-semibold text-slate-600">
              <li class="flex justify-between py-2.5 border-b border-slate-200/60">
                <span class="text-slate-400">Format officiel</span>
                <span class="text-primary-navy">Fichier d'attestation au format XML / PDF</span>
              </li>
              <li class="flex justify-between py-2.5 border-b border-slate-200/60">
                <span class="text-slate-400">Destination</span>
                <span class="text-primary-navy">À joindre à la DAACT en Mairie</span>
              </li>
              <li class="flex justify-between py-2.5 border-b border-slate-200/60">
                <span class="text-slate-400">Délai d'édition</span>
                <span class="text-primary-orange">Sous 24h après validation site</span>
              </li>
              <li class="flex justify-between py-2.5 border-b border-slate-200/60">
                <span class="text-slate-400">Validité réglementaire</span>
                <span class="text-primary-navy">Obligatoire RE2020 / RT2012</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SECTION COPYWRITING : LES BÉNÉFICES BUSINESS -->
    <section id="pourquoi" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 scroll-mt-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-2xl md:text-3xl font-extrabold font-display text-primary-navy uppercase tracking-tight">
          La clé pour débloquer la livraison de votre bâtiment
        </h2>
        <p class="text-sm md:text-base text-slate-500 font-medium mt-3">
          L'attestation finale n'est pas qu'une simple formalité, c'est le bouclier juridique de votre projet immobilier.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Carte Bénéfice 1 -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-primary-orange flex items-center justify-center mb-6">
            <Icon name="lucide:gavel" class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-primary-navy mb-3">Conformité juridique totale</h3>
          <p class="text-sm text-slate-500 leading-relaxed font-medium">
            Déposer une DAACT sans son attestation de fin de travaux expose le maître d'ouvrage au refus de conformité de la mairie. Nous éditons un document inattaquable selon les derniers décrets de la RE2020.
          </p>
        </div>

        <!-- Carte Bénéfice 2 -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-primary-orange flex items-center justify-center mb-6">
            <Icon name="lucide:clock" class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-primary-navy mb-3">Zéro délai sur vos livraisons</h3>
          <p class="text-sm text-slate-500 leading-relaxed font-medium">
            Les banques et les notaires exigent ce précieux Cerfa pour débloquer les derniers appels de fonds ou signer l'acte de vente définitif. Grâce à notre réactivité sous 24h, vous ne bloquez pas vos transactions.
          </p>
        </div>

        <!-- Carte Bénéfice 3 -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-primary-orange flex items-center justify-center mb-6">
            <Icon name="lucide:file-search" class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-primary-navy mb-3">Contrôle de cohérence final</h3>
          <p class="text-sm text-slate-500 leading-relaxed font-medium">
            Nous consolidons l'étude thermique initiale avec la réalité des tests physiques d'infiltrométrie et de VMC menés sur site. C'est l'assurance qu'aucune erreur de saisie ne viendra invalider votre travail.
          </p>
        </div>
      </div>
    </section>

    <!-- 3. SECTION PROCESS : COMMENT ÇA SE PASSE -->
    <section class="w-full bg-white border-y border-slate-100 py-16 mb-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-xs font-bold text-primary-orange uppercase tracking-widest block mb-2">Méthodologie ACCTHERM</span>
          <h2 class="text-2xl md:text-3xl font-black font-display text-primary-navy uppercase tracking-tight">
            Les 4 étapes vers votre Cerfa de conformité
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 relative">
          <!-- Étape 1 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">01</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Collecte du fichier RSET</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Récupération de l'étude thermique au format standardisé XML générée lors de la phase de conception de votre projet.</p>
          </div>
          <!-- Étape 2 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">02</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Visite de contrôle de cohérence</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Vérification visuelle sur site de la bonne mise en œuvre des isolants et de la conformité des systèmes de chauffage déclarés.</p>
          </div>
          <!-- Étape 3 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">03</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Agrégation des rapports</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Croisement des données terrain avec vos rapports officiels d'infiltrométrie finale et de mesures de VMC Promevent.</p>
          </div>
          <!-- Étape 4 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">04</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Délivrance de l'Attestation</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Génération sur le portail du ministère du fichier d'attestation signé électroniquement, prêt pour votre dépôt en mairie.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. FAQ SPÉCIFIQUE -->
    <FAQ title="Questions fréquentes sur l'attestation Cerfa" faqs={attestationFaqs} />

    <!-- 5. LE COMPOSANT CONTACT -->
    <Contact />

  </main>
  <Footer />
</Layout>