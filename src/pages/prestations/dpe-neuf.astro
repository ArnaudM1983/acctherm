---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FAQ from "../../components/FAQ.astro";
import Contact from "../../components/Contact.astro";
import { Icon } from 'astro-icon/components';

const pageTitle = "DPE Neuf Lyon | Diagnostic Performance Énergétique Construction";
const pageDescription = "Réalisation de votre DPE Neuf obligatoire pour maison individuelle à Lyon et Rhône-Alpes. Profitez de notre passage de conformité RE2020.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Diagnostic de Performance Énergétique (DPE Neuf)",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://acctherm.com/#localbusiness"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Auvergne-Rhône-Alpes",
        "sameAs": "https://www.wikidata.org/wiki/Q18247094"
      },
      "description": "Établissement du Diagnostic de Performance Énergétique obligatoire pour les constructions neuves lors de la réception de chantier."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://acctherm.com" },
        { "@type": "ListItem", "position": 2, "name": "Prestations", "item": "https://acctherm.com/prestations" },
        { "@type": "ListItem", "position": 3, "name": "DPE Neuf", "item": "https://acctherm.com/prestations/dpe-neuf" }
      ]
    }
  ]
};

const dpeFaqs = [
  {
    question: "Qu'est-ce que le DPE Neuf (ou DPE Construction) ?",
    answer: "Le DPE Neuf est un diagnostic de performance énergétique obligatoire pour toute construction neuve. Contrairement à un DPE classique de rénovation, il est calculé à partir du récapitulatif standardisé d'étude thermique (RSET) et validé par une vérification visuelle de notre technicien sur site."
  },
  {
    question: "Pourquoi réaliser le DPE Neuf en même temps que vos contrôles RE2020 ?",
    answer: "C'est un gain de temps et d'argent considérable. Lors de notre passage sur votre chantier à Lyon pour valider la perméabilité à l'air et le contrôle de la ventilation, nous réalisons simultanément les relevés physiques pour votre DPE. Vous évitez ainsi de payer les frais de déplacement d'un autre diagnostiqueur."
  },
  {
    question: "Proposez-vous des audits énergétiques réglementaires ?",
    answer: "Non. Chez ACCTHERM, nous sommes spécialisés exclusivement dans le DPE Neuf lié à la construction de maisons individuelles (hors Audit Énergétique global). C'est ce focus technique précis qui nous permet de vous délivrer une prestation ultra-réactive et conforme."
  }
];
---

<Layout title={pageTitle} description={pageDescription} schema={serviceSchema}>
  <Header />
  
  <main class="grow bg-[#f8fafc]">
    
    <!-- 1. HERO SECTION SÉMANTIQUE -->
    <section class="w-full bg-white border-b border-slate-100 relative overflow-hidden pt-16 pb-16">
      <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <!-- BREADCRUMB -->
        <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-xs font-semibold text-slate-400 mb-6">
          <a href="/" class="hover:text-primary-orange transition-colors">Accueil</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <a href="/prestations" class="hover:text-primary-orange transition-colors">Prestations</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <span class="text-slate-600" aria-current="page">DPE Neuf</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7 text-left">
            <span class="inline-block bg-orange-100 text-primary-orange text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg mb-6">
              Performance Énergétique Obligatoire Maison Individuelle
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-black font-display text-primary-navy leading-[1.1] mb-6 tracking-tight">
              DPE Neuf et Étiquette Énergétique <span class="text-primary-orange">à Lyon</span>
            </h1>
            <p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed font-medium max-w-2xl">
              Optimisez votre logistique de fin de chantier. <span class="text-primary-navy font-bold">Lors de notre passage sur site pour la validation réglementaire de votre maison neuve RE2020, nous réalisons simultanément votre DPE Neuf.</span> Un calcul précis basé sur vos données réelles pour éditer vos étiquettes A-G officielles sans multiplier les intervenants.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contact" class="bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all shadow-lg shadow-orange-200 text-center cursor-pointer flex items-center justify-center gap-2">
                <Icon name="lucide:activity" class="w-4 h-4" /> Coupler mon DPE à mes contrôles
              </a>
              <a href="#pourquoi" class="border-2 border-primary-navy text-primary-navy font-bold py-4 px-8 rounded-xl text-sm hover:bg-primary-navy hover:text-white transition-all text-center cursor-pointer">
                Pourquoi nous confier le DPE ?
              </a>
            </div>
          </div>
          
          <!-- Encart technique visuel de droite -->
          <div class="lg:col-span-5 bg-slate-50 border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
            <h3 class="text-sm font-bold text-primary-navy uppercase tracking-wider mb-4 flex items-center gap-2">
              <Icon name="lucide:combine" class="text-primary-orange w-4 h-4" /> La synergie intelligente
            </h3>
            <p class="text-xs text-slate-500 font-medium mb-4">Pourquoi faire déplacer une autre entreprise ? Profitez de notre présence technique obligatoire pour régler la question du DPE.</p>
            <ul class="space-y-3 text-xs md:text-sm font-semibold text-slate-600">
              <li class="flex items-center gap-2.5 py-1.5 border-b border-slate-200/60">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Relevés techniques faits en même temps que l'infiltrométrie
              </li>
              <li class="flex items-center gap-2.5 py-1.5 border-b border-slate-200/60">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Validation de la cohérence des isolants et chauffages posés
              </li>
              <li class="flex items-center gap-2.5">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Transmission rapide du numéro ADEME officiel
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SECTION COPYWRITING : LES BÉNÉFICES BUSINESS -->
    <section id="pourquoi" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 scroll-mt-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-2xl md:text-3xl font-extrabold font-display text-primary-navy uppercase tracking-tight">
          La performance énergétique certifiée sans surcoût inutile
        </h2>
        <p class="text-sm md:text-base text-slate-500 font-medium mt-3">
          Regrouper vos relevés de fin de chantier avec ACCTHERM, c'est l'assurance d'une clôture de dossier fluide et économique.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Carte Bénéfice 1 -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-primary-orange flex items-center justify-center mb-6">
            <Icon name="lucide:coins" class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-primary-navy mb-3">Économies sur les frais de déplacement</h3>
          <p class="text-sm text-slate-500 leading-relaxed font-medium">
            Faire déplacer un diagnostiqueur tiers uniquement pour le DPE construction engendre des frais fixes superflus. En couplant cette mesure avec l'infiltrométrie finale ou le contrôle VMC, vous rationalisez votre budget de fin de chantier.
          </p>
        </div>

        <!-- Carte Bénéfice 2 -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-primary-orange flex items-center justify-center mb-6">
            <Icon name="lucide:calendar-days" class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-primary-navy mb-3">Une seule immobilisation de chantier</h3>
          <p class="text-sm text-slate-500 leading-relaxed font-medium">
            Pas besoin de caler plusieurs rendez-vous dans un planning de livraison déjà saturé. Tom ou Pierre réalise l'ensemble des constatations visuelles et des relevés d'équipements thermiques en une seule et unique intervention sur site.
          </p>
        </div>

        <!-- Carte Bénéfice 3 -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-orange-50 text-primary-orange flex items-center justify-center mb-6">
            <Icon name="lucide:database" class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-primary-navy mb-3">Transmission officielle ADEME sous 24h</h3>
          <p class="text-sm text-slate-500 leading-relaxed font-medium">
            Une fois la cohérence validée entre l'étude thermique (RSET) et les éléments posés, nous générons vos étiquettes énergétiques officielles et téléchargeons le dossier directement sur la base d'État ADEME pour une disponibilité immédiate.
          </p>
        </div>
      </div>
    </section>

    <!-- 3. SECTION PROCESS : COMMENT ÇA SE PASSE -->
    <section class="w-full bg-white border-y border-slate-100 py-16 mb-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-xs font-bold text-primary-orange uppercase tracking-widest block mb-2">Méthodologie ACCTHERM</span>
          <h2 class="text-2xl md:text-3xl font-black font-display text-primary-navy uppercase tracking-tight">
            Le protocole de réalisation du DPE Neuf
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 relative">
          <!-- Étape 1 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">01</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Analyse du fichier d'étude</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Importation et étude approfondie de votre fichier d'étude thermique RSET calculé en phase de conception pour extraire les performances théoriques du bâti.</p>
          </div>
          <!-- Étape 2 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">02</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Vérification des composants</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Contrôle visuel sur site (lors de nos tests d'infiltrométrie/VMC) de la conformité des isolants, de la nature des vitrages et de la marque des systèmes de chauffage posés.</p>
          </div>
          <!-- Étape 3 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">03</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Calcul de performance</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Saisie des données et des surfaces de parois dans notre logiciel certifié pour générer les notes de consommations d'énergie et d'émissions de GES.</p>
          </div>
          <!-- Étape 4 -->
          <div class="relative">
            <div class="text-4xl font-black text-orange-200 mb-4 font-display">04</div>
            <h4 class="text-base font-bold text-primary-navy mb-2">Dépôt ADEME & Livraison</h4>
            <p class="text-xs md:text-sm text-slate-500 font-medium leading-relaxed">Attribution du numéro officiel d'enregistrement ADEME et envoi de votre rapport de DPE Neuf sous 24h, document valable pendant 10 ans.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. FAQ SPÉCIFIQUE -->
    <FAQ title="Questions fréquentes sur le DPE Construction" faqs={dpeFaqs} />

    <!-- 5. LE COMPOSANT CONTACT -->
    <Contact />

  </main>
  <Footer />
</Layout>