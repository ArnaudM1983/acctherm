---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FAQ from "../../components/FAQ.astro";
import Contact from "../../components/Contact.astro";
import { Icon } from 'astro-icon/components';

const pageTitle = "DPE Neuf Lyon | Diagnostic Performance Énergétique Construction";
const pageDescription = "Réalisation de votre DPE Neuf obligatoire pour maison individuelle à Lyon et Rhône-Alpes. Profitez de notre passage de conformité RE2020.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "serviceType": "Diagnostic de Performance Énergétique (DPE Neuf)",
      "provider": {
        "@type": "LocalBusiness",
        "@id": "https://acctherm.com/#localbusiness"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Auvergne-Rhône-Alpes",
        "sameAs": "https://www.wikidata.org/wiki/Q18247094"
      },
      "description": "Établissement du Diagnostic de Performance Énergétique obligatoire pour les constructions neuves lors de la réception de chantier."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://acctherm.com" },
        { "@type": "ListItem", "position": 2, "name": "Prestations", "item": "https://acctherm.com/prestations" },
        { "@type": "ListItem", "position": 3, "name": "DPE Neuf", "item": "https://acctherm.com/prestations/dpe-neuf" }
      ]
    }
  ]
};

const dpeFaqs = [
  {
    question: "Qu'est-ce que le DPE Neuf (ou DPE Construction) ?",
    answer: "Le DPE Neuf est un diagnostic de performance énergétique obligatoire pour toute construction neuve. Contrairement à un DPE classique de rénovation, il est calculé à partir du récapitulatif standardisé d'étude thermique (RSET) et validé par une vérification visuelle de notre technicien sur site."
  },
  {
    question: "Pourquoi réaliser le DPE Neuf en même temps que vos contrôles RE2020 ?",
    answer: "C'est un gain de temps et d'argent considérable. Lors de notre passage sur votre chantier à Lyon pour valider la perméabilité à l'air et le contrôle de la ventilation, nous réalisons simultanément les relevés physiques pour votre DPE. Vous évitez ainsi de payer les frais de déplacement d'un autre diagnostiqueur."
  },
  {
    question: "Proposez-vous des audits énergétiques réglementaires ?",
    answer: "Non. Chez ACCTHERM, nous sommes spécialisés exclusivement dans le DPE Neuf lié à la construction de maisons individuelles (hors Audit Énergétique global). C'est ce focus technique précis qui nous permet de vous délivrer une prestation ultra-réactive et conforme."
  }
];
---

<Layout title={pageTitle} description={pageDescription} schema={serviceSchema}>
  <Header />
  
  <main class="grow bg-[#f8fafc]">
    
    <section class="w-full bg-white border-b border-slate-100 relative overflow-hidden pt-12 pb-16 md:py-24">
      <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <nav aria-label="Fil d'Ariane" class="flex items-center gap-2 text-xs font-semibold text-slate-400 mb-6">
          <a href="/" class="hover:text-primary-orange transition-colors">Accueil</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <a href="/prestations" class="hover:text-primary-orange transition-colors">Prestations</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 text-slate-300" />
          <span class="text-slate-600" aria-current="page">DPE Neuf</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7 text-left">
            <span class="inline-block bg-orange-100 text-primary-orange text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg mb-6">
              Performance Énergétique Obligatoire Maison Individuelle
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-black font-display text-primary-navy leading-[1.1] mb-6 tracking-tight">
              DPE Neuf et Étiquette Énergétique <span class="text-primary-orange">à Lyon</span>
            </h1>
            <p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed font-medium max-w-2xl">
              Optimisez votre logistique de fin de chantier. <span class="text-primary-navy font-bold">Lors de notre passage sur site pour la validation réglementaire de votre maison neuve RE2020, nous réalisons simultanément votre DPE Neuf.</span> Un calcul précis basé sur vos données réelles pour éditer vos étiquettes A-G officielles sans multiplier les intervenants.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contact" class="bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all shadow-lg shadow-orange-200 text-center cursor-pointer flex items-center justify-center gap-2">
                <Icon name="lucide:activity" class="w-4 h-4" /> Coupler mon DPE à mes contrôles
              </a>
            </div>
          </div>
          
          <div class="lg:col-span-5 bg-slate-50 border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
            <h3 class="text-sm font-bold text-primary-navy uppercase tracking-wider mb-4 flex items-center gap-2">
              <Icon name="lucide:combine" class="text-primary-orange w-4 h-4" /> La synergie intelligente
            </h3>
            <p class="text-xs text-slate-500 font-medium mb-4">Pourquoi faire déplacer une autre entreprise ? Profitez de notre présence technique obligatoire pour régler la question du DPE.</p>
            <ul class="space-y-3 text-xs md:text-sm font-semibold text-slate-600">
              <li class="flex items-center gap-2.5 py-1.5 border-b border-slate-200/60">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Relevés techniques faits en même temps que l'infiltrométrie
              </li>
              <li class="flex items-center gap-2.5 py-1.5 border-b border-slate-200/60">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Validation de la cohérence des isolants et chauffages posés
              </li>
              <li class="flex items-center gap-2.5">
                <Icon name="lucide:check" class="text-emerald-500 w-4 h-4" /> Transmission rapide du numéro ADEME officiel
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <FAQ title="Questions fréquentes sur le DPE Construction" faqs={dpeFaqs} />
    <Contact />
  </main>
  <Footer />
</Layout>