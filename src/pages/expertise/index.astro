---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FAQ from "../../components/FAQ.astro";
import Contact from "../../components/Contact.astro"; 
import { Icon } from "astro-icon/components";

// Données sémantiques de la page pour le SEO
const pageTitle = "Centre de Ressources Techniques & Expertises RE2020 | ACCTHERM";
const pageDescription = "Explorez les guides techniques d'ACCTHERM : réglementation RE2020, infiltrométrie, protocole Promevent, QAI et recherche de fuites à Lyon.";

// Schéma spécifique pour le Centre de Ressources
const expertiseSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://acctherm.com/expertise/#webpage",
  "url": "https://acctherm.com/expertise",
  "name": "Centre de Ressources Techniques et Expertises RE2020",
  "description": pageDescription,
  "isPartOf": {
    "@id": "https://acctherm.com/#website"
  }
};

// Liste des dossiers techniques (les expertises)
const guides = [
  { 
    title: "Guide Complet de la Réglementation RE2020", 
    desc: "Tout comprendre sur les nouvelles exigences thermiques et environnementales.", 
    url: "/expertise/guide-re2020",
    icon: "lucide:file-text"
  },
  { 
    title: "Recherche de Fuites & Ponts Thermiques", 
    desc: "Expertise technique sur l'usage des fumigènes et de la thermographie.", 
    url: "/expertise/recherche-de-fuites",
    icon: "lucide:search"
  },
  { 
    title: "La Qualité de l'Air Intérieur (QAI) & Santé", 
    desc: "L'importance cruciale du renouvellement d'air et de l'étanchéité des réseaux.", 
    url: "/expertise/qualite-air-interieur",
    icon: "lucide:wind"
  },
  { 
    title: "Test Intermédiaire vs Test Final", 
    desc: "Pourquoi et quand réaliser un test d'infiltrométrie en cours de chantier.", 
    url: "/expertise/test-intermediaire-vs-final",
    icon: "lucide:git-compare"
  },
  { 
    title: "Checklist : Préparer son test d'étanchéité", 
    desc: "Guide pratique pour éviter un échec ou une contre-visite au contrôle.", 
    url: "/expertise/checklist-preparation-test",
    icon: "lucide:check-square"
  }
];

// Tableau des FAQs adapté au centre de ressources
const expertiseFaqs = [
  { 
    question: "À qui s'adressent ces dossiers techniques et réglementaires ?", 
    answer: "Nos ressources s'adressent à l'ensemble des acteurs de la construction en Auvergne-Rhône-Alpes : maîtres d'œuvre, architectes, artisans du bâtiment (plaquistes, électriciens, plombiers) ainsi qu'aux particuliers désireux de comprendre les obligations techniques de leur future maison individuelle." 
  },
  { 
    question: "Les guides intègrent-ils les dernières mises à jour de la RE2020 ?", 
    answer: "Oui, notre centre de ressources est régulièrement actualisé par nos contrôleurs agréés selon les retours d'expérience terrain et les évolutions des textes législatifs ou du protocole réglementaire Promevent." 
  },
  { 
    question: "Puis-je solliciter ACCTHERM pour une sensibilisation technique sur chantier ?", 
    answer: "Tout à fait. Au-delà des guides écrits, nous organisons des sessions de conseil et d'accompagnement directement sur vos chantiers autour de Lyon pour former vos équipes aux bonnes pratiques de l'étanchéité à l'air et de la ventilation." 
  }
];
---

<Layout title={pageTitle} description={pageDescription} schema={expertiseSchema}>
  <Header />
  
  <main class="grow bg-[#f8fafc]">
    
    <section class="w-full bg-white border-b border-slate-100 relative overflow-hidden pt-12 pb-16">
      <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] bg-size-[16px_16px] opacity-40 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 pt-10">
        <span class="inline-block bg-orange-100 text-primary-orange text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg mb-4">
          Autorité & Éducation
        </span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-black font-display text-primary-navy leading-tight mb-6 max-w-3xl mx-auto">
          Notre Centre de <span class="text-primary-orange">Ressources Techniques</span>
        </h1>
        <p class="text-base md:text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed font-medium">
          La performance énergétique et le respect de la RE2020 ne s'improvisent pas. Que vous soyez artisan, architecte ou maître d'ouvrage, explorez nos dossiers d'experts.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-extrabold font-display text-primary-navy uppercase tracking-tight">
          Sélectionnez un dossier technique
        </h2>
        <p class="text-sm text-slate-500 font-medium mt-2">Cliquez sur un dossier technique pour ouvrir le guide complet</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          guides.map((guide) => (
            <a
              href={guide.url}
              class="group bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:border-primary-orange/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col gap-4 text-left cursor-pointer"
            >
              <div class="bg-orange-50 w-12 h-12 rounded-xl flex items-center justify-center text-primary-orange group-hover:bg-primary-orange group-hover:text-white transition-all duration-300 shrink-0">
                <Icon name={guide.icon} class="w-6 h-6" />
              </div>
              <div class="flex flex-col gap-2">
                <h3 class="font-bold text-primary-navy text-base group-hover:text-primary-orange transition-colors duration-300 leading-tight">
                  {guide.title}
                </h3>
                <p class="text-sm text-slate-500 font-medium leading-relaxed">
                  {guide.desc}
                </p>
              </div>
              <div class="mt-auto pt-4 flex items-center text-xs font-bold text-primary-orange uppercase tracking-widest">
                Ouvrir le dossier →
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div class="bg-primary-navy text-white rounded-3xl p-8 md:p-12 shadow-lg relative overflow-hidden text-center md:text-left flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="absolute inset-0 bg-[radial-gradient(#ffffff_1px,transparent_1px)] bg-size-[24px_24px] opacity-5 pointer-events-none"></div>
        
        <div class="max-w-2xl relative z-10">
          <span class="text-xs font-bold text-primary-orange uppercase tracking-widest block mb-2">Besoin d'un conseil spécifique ?</span>
          <h2 class="text-white text-xl md:text-2xl font-black font-display uppercase tracking-tight mb-4">
            Une question sur la conformité de vos plans ?
          </h2>
          <p class="text-slate-300 text-sm md:text-base leading-relaxed font-medium">
            Nos experts vous aident à analyser l'étanchéité et les systèmes de ventilation de votre projet de construction pour sécuriser vos futurs tests d'infiltrométrie.
          </p>
        </div>
        
        <div class="shrink-0 relative z-10 w-full md:w-auto">
          <a href="#contact" class="inline-block w-full md:w-auto bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all text-center cursor-pointer shadow-lg ">
            Contacter un expert thermique
          </a>
        </div>
      </div>
    </section>

    <FAQ title="Des réponses à vos questions techniques" faqs={expertiseFaqs} />

    <Contact />

  </main>

  <Footer />
</Layout>