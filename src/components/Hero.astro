---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-image.webp';
---

<section id="hero" class="w-full bg-white border-b border-slate-100 relative overflow-hidden group">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 flex flex-col lg:flex-row justify-between items-center gap-12 relative z-10">
    
    <div class="w-full lg:w-[55%] text-left">
      <span class="inline-block bg-orange-100 text-primary-orange text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg mb-6">
        Société de contrôle énergétique agréée Qualibat 8711 & 8741
      </span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold font-display text-primary-navy leading-[1.1] mb-6 tracking-tight">
        Test d’Infiltrométrie et Conformité RE2020 <span class="text-primary-orange">à Lyon</span>
      </h1>
      <p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed font-medium max-w-2xl">
        Depuis 15 ans, ACCTHERM sécurise vos chantiers en Auvergne-Rhône-Alpes. Contrôle d'étanchéité à l'air et VMC (Promevent) avec rapports réglementaires sous 24h pour obtenir votre attestation de fin de travaux sans stress.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#contact" class="bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all shadow-lg shadow-orange-200/50 text-center cursor-pointer">
          Obtenir mon Devis Gratuit
        </a>
        <a href="#contact" class="border-2 border-primary-navy text-primary-navy font-bold py-4 px-8 rounded-xl text-sm hover:bg-primary-navy hover:text-white transition-all shadow-sm text-center cursor-pointer">
          Être rappelé par un expert
        </a>
      </div>
    </div>
    
    <div class="w-full lg:w-[45%] flex justify-center lg:justify-end group-hover:scale-105 transition-transform duration-700">
      <Image 
        src={heroImage} 
        alt="Vue d'une caméra thermique" 
        class="w-full max-w-xs lg:max-w-md h-auto object-cover rounded-2xl shadow-lg lg:shadow-xl" 
        loading="eager"
      />
    </div>

  </div>
  
  <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-1/3 bg-slate-50/60 -skew-x-12 origin-top-right pointer-events-none"></div>
</section>