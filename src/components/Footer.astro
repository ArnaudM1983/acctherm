---
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="bg-primary-navy text-white px-4 sm:px-8 py-4 flex justify-between items-center shrink-0 mt-auto">
  <div class="flex items-center gap-4 md:gap-8 flex-wrap">
    <div class="text-[10px] uppercase tracking-widest font-bold opacity-60">
      © {currentYear} ACCTHERM
    </div>
    <div class="hidden sm:flex gap-4 text-[10px] md:text-[11px] font-bold text-blue-200/50 uppercase tracking-tighter">
      <span>Lyon & Rhône-Alpes</span>
      <span class="opacity-20">|</span>
      <span>Conformité RE2020</span>
      <span class="opacity-20">|</span>
      <span>VMC & DPE</span>
    </div>
  </div>
  <div class="text-[10px] md:text-[11px] text-right text-orange-200 font-bold uppercase tracking-widest">
    Expert : Pascal Poulanges — Bureau Technique
  </div>
</footer>