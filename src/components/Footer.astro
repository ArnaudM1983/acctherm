---
import { Icon } from 'astro-icon/components';
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="bg-primary-navy text-white mt-auto shrink-0">
  <section class="px-4 sm:px-8 py-12 lg:py-16 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    
    <div class="flex flex-col text-left">
      <h3 class="text-2xl sm:text-3xl font-bold font-display text-white mb-6 leading-tight">
        ACCTHERM : Votre partenaire de proximité à Lyon et Rhône-Alpes-Auvergne
      </h3>
      <p class="text-sm sm:text-base text-slate-300 mb-8 leading-relaxed font-medium opacity-90 max-w-xl">
        Plus qu'un simple prestataire, nous sommes vos garants réglementaires. Fort de 15 ans d'expérience dans l'ingénierie du bâtiment, ACCTHERM assure une conformité totale avec les certifications Qualibat 8711 & 8741, assurant la validité juridique de vos attestations de fin de travaux.
      </p>
      
      <div class="grid grid-cols-2 gap-6 mb-8 max-w-md">
        <div>
          <p class="text-2xl sm:text-3xl font-extrabold font-display text-white">15+</p>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-tight mt-1">Années d'expertise</p>
        </div>
        <div>
          <p class="text-2xl sm:text-3xl font-extrabold font-display text-white">8711 - 8741</p>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-tight mt-1">Qualibat Certification</p>
        </div>
      </div>

      <div>
        <a href="#contact" class="inline-block text-center bg-primary-orange hover:bg-primary-orange-hover text-white font-bold py-4 px-8 rounded-xl text-sm transition-all shadow-lg shadow-orange-950/50 cursor-pointer">
          Contacter notre agence lyonnaise
        </a>
      </div>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8 flex flex-col backdrop-blur-sm">
      
      <!-- 🔹 Zone de la Carte avec l'effet SVG superposé -->
      <div class="w-full h-40 bg-slate-800/40 border border-white/5 rounded-xl mb-6 relative overflow-hidden group shadow-inner">
        
        <!-- 1. L'Iframe OpenStreetMap en arrière-plan -->
        <iframe 
          class="w-full h-full border-0 opacity-80 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none sm:pointer-events-auto"
          src="https://www.openstreetmap.org/export/embed.html?bbox=4.7800%2C45.7200%2C4.9000%2C45.7900&amp;layer=mapnik&amp;marker=45.7578%2C4.8320"
          style="filter: invert(90%) hue-rotate(180deg) brightness(85%) contrast(90%);"
          title="Carte de Lyon - ACCTHERM"
          loading="lazy"
        >
        </iframe>

        <!-- 2. Le Calque SVG et l'icône animée superposés par-dessus (clic-traversant autorisé) -->
        <div class="absolute inset-0 w-full h-full flex items-center justify-center pointer-events-none select-none z-10">
          <svg class="absolute inset-0 w-full h-full opacity-25 group-hover:scale-105 transition-transform duration-700" viewBox="0 0 400 200" fill="none" stroke="currentColor">
            <circle cx="200" cy="100" r="30" stroke-width="1" stroke-dasharray="2 2" />
            <circle cx="200" cy="100" r="60" stroke-width="0.5" />
            <line x1="0" y1="100" x2="400" y2="100" stroke-width="0.5" />
            <line x1="200" y1="0" x2="200" y2="200" stroke-width="0.5" />
          </svg>
          
          <!-- La flèche de localisation qui rebondit -->
          <div class="relative bg-primary-navy p-2 rounded-full shadow-md border border-white/10 text-primary-orange animate-bounce">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2a8 8 0 0 0-8 8c0 5.25 7 12 7 12s7-6.75 7-12a8 8 0 0 0-8-8zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
            </svg>
          </div>
        </div>

        <!-- Petit badge de rappel de secteur -->
        <div class="absolute bottom-2 left-2 bg-primary-navy/80 backdrop-blur-sm text-[9px] font-bold text-slate-300 px-2 py-0.5 rounded border border-white/5 pointer-events-none uppercase tracking-wider z-20">
          Secteur Métropole de Lyon
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
        
        <div class="flex flex-col text-left justify-between">
          <div>
            <h4 class="text-lg font-bold font-display text-white mb-1">Agence Lyon - Rhône</h4>
            <p class="text-xs text-slate-300 font-medium mb-3">69000 Lyon, France</p>
          </div>
          
          <div class="space-y-2.5 border-t border-white/10 pt-3">
            <div>
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Lignes directes</p>
            </div>
            <div>
              <p class="text-xs font-bold text-white">Tom POULANGES</p>
              <a href="tel:0695311758" class="text-xs text-slate-300 hover:text-primary-orange transition-colors flex items-center gap-1 mt-0.5">
                <Icon name="lucide:phone" class="w-3 h-3 text-slate-400" /> 06.95.31.17.58
              </a>
            </div>
            <div>
              <p class="text-xs font-bold text-white">Pierre POULANGES</p>
              <a href="tel:0634583303" class="text-xs text-slate-300 hover:text-primary-orange transition-colors flex items-center gap-1 mt-0.5">
                <Icon name="lucide:phone" class="w-3 h-3 text-slate-400" /> 06.34.58.33.03
              </a>
            </div>
          </div>
        </div>

        <div class="flex flex-col text-left bg-white/5 border border-white/5 rounded-xl p-4 h-full justify-start">
          <h5 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3 border-b border-white/10 pb-1.5 flex items-center gap-1.5">
            <Icon name="lucide:clock" class="w-3.5 h-3.5 text-slate-400" /> Heures d'ouverture
          </h5>
          <div class="space-y-3">
            <div class="flex justify-between items-center text-xs">
              <span class="font-semibold text-slate-300">Lun - Ven</span>
              <span class="font-bold text-white bg-white/10 px-2 py-0.5 rounded text-[11px]">09:00 - 17:00</span>
            </div>
            <div class="flex justify-between items-center text-xs">
              <span class="font-semibold text-slate-400">Sam - Dim</span>
              <span class="font-medium text-red-400/80 italic bg-red-500/10 px-2 py-0.5 rounded text-[11px]">Fermé</span>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-4 mt-auto border-t border-white/10 pt-4">
        <div class="bg-white px-4 py-2.5 rounded-lg flex items-center justify-center h-9 w-24 select-none">
          <span class="text-[10px] font-black tracking-tighter text-primary-navy font-display">ACCTHERM</span>
        </div>
        <div class="bg-white px-4 py-2.5 rounded-lg flex items-center justify-center h-9 w-24 select-none">
          <span class="text-[10px] font-extrabold tracking-tight text-[#0f2c59] font-sans">ADEME</span>
        </div>
      </div>
    </div>
  </section>

  <div class="border-t border-white/10 w-full"></div>

  <div class="px-4 sm:px-8 py-6 max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-4 md:gap-8 flex-wrap justify-center sm:justify-start">
      <div class="text-[10px] uppercase tracking-widest font-bold opacity-60">
        © {currentYear} ACCTHERM
      </div>
      <div class="hidden sm:flex gap-4 text-[10px] md:text-[11px] font-bold text-blue-200/50 uppercase tracking-wider">
        <span>Lyon & Rhône-Alpes</span>
        <span class="opacity-20">|</span>
        <span>Conformité RE2020</span>
        <span class="opacity-20">|</span>
        <span>VMC & DPE</span>
      </div>
      <div class="flex gap-4 text-[10px] md:text-[11px] font-bold uppercase tracking-wider">
        <span class="hidden sm:inline opacity-20 text-blue-200/50">|</span>
        <a href="/mentions-legales" class="text-slate-300 hover:text-primary-orange transition-colors duration-300">Mentions légales</a>
        <span class="opacity-20 text-blue-200/50">|</span>
        <a href="/politique-confidentialite" class="text-slate-300 hover:text-primary-orange transition-colors duration-300">Confidentialité</a>
        <span class="opacity-20 text-blue-200/50">|</span>
        <a href="/politique-cookies" class="text-slate-300 hover:text-primary-orange transition-colors duration-300">Cookies</a>
      </div>
    </div>
    <div class="text-[10px] md:text-[11px] text-center sm:text-right text-orange-200 font-bold uppercase tracking-widest">
      Société de contrôle énergétique agréée
    </div>
  </div>
</footer>