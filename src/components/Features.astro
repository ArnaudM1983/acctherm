---
import { Icon } from 'astro-icon/components';

const features = [
  { icon: "lucide:map-pin", title: "Ancrage Local Réactif", description: "Intervention rapide sur Lyon, Villeurbanne et toute la région Auvergne-Rhône-Alpes (69, 01, 38)." },
  { icon: "lucide:shield-check", title: "Garantie Conformité", description: "Certifications Qualibat 8711 et 8721 pour une validation sans faille de vos attestations de fin de chantier." },
  { icon: "lucide:search", title: "Expertise 20 Ans", description: "Une analyse fine des ponts thermiques et de l'enveloppe du bâtiment pour réduire durablement vos factures d'énergie." },
  { icon: "lucide:users", title: "Accompagnement", description: "Des rapports clairs et pédagogiques adaptés à chaque interlocuteur, du conducteur de travaux au propriétaire." },
];
---

<section id="features" class="px-4 sm:px-6 lg:px-8 pb-8">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    {features.map((feature, index) => (
      <div id={`feature-card-${index}`} class="bg-white p-4 md:p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col items-center text-center group hover:border-primary-orange/30 transition-all cursor-default">
        <div class="bg-blue-50 p-3 rounded-full mb-4 text-primary-navy group-hover:scale-110 transition-transform">
          <Icon name={feature.icon} class="w-6 h-6" />
        </div>
        <h4 class="text-[10px] md:text-xs font-bold text-primary-navy mb-1 uppercase tracking-tighter leading-tight">
          {feature.title}
        </h4>
        <p class="text-[9px] md:text-[11px] text-slate-500 leading-relaxed font-medium">
          {feature.description.split('|')[0].trim()}
        </p>
      </div>
    ))}
  </div>
</section>