---
import { Icon } from 'astro-icon/components';

const features = [
  { icon: "lucide:map-pin", title: "Ancrage Local Réactif", description: "Intervention rapide sur Lyon, Villeurbanne et toute la région Auvergne-Rhône-Alpes (69, 01, 38, 42, 07, 26, 43, 73, 74, 63)." },
  { icon: "lucide:shield-check", title: "Garantie Conformité", description: "Certifications 8711 et 8741 QUALIBAT pour une validation sans faille de vos attestations de fin de chantier." },
  { icon: "lucide:search", title: "Expertise 15 Ans", description: "Une traque précise des fuites d'air et un contrôle rigoureux de la ventilation pour garantir la conformité RE2020 de votre bâtiment." },
  { icon: "lucide:users", title: "Accompagnement", description: "Des rapports clairs et pédagogiques adaptés à chaque interlocuteur, du conducteur de travaux au propriétaire." },
];
---

<section id="features" class="px-4 sm:px-6 lg:px-8 pb-8 max-w-7xl mx-auto w-full pt-12">
  <div class="grid lg:grid-cols-4 gap-4">
    {features.map((feature, index) => (
      <div id={`feature-card-${index}`} class="bg-white p-4 md:p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col items-center text-center group hover:border-primary-orange/30 transition-all cursor-default">
        <div class="bg-blue-50 p-3 rounded-full mb-4 text-primary-navy group-hover:scale-110 transition-transform">
          <Icon name={feature.icon} class="w-6 h-6" />
        </div>
        <h4 class="text-[14px] md:text-lg font-bold text-primary-navy mb-1 uppercase tracking-tighter leading-tight">
          {feature.title}
        </h4>
        <p class="text-[12px] md:text-sm text-slate-500 leading-relaxed font-medium">
          {feature.description.split('|')[0].trim()}
        </p>
      </div>
    ))}
  </div>
</section>