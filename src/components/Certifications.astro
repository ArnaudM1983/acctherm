---
import { Icon } from 'astro-icon/components';
---

<section id="certifications" class="px-4 sm:px-6 lg:px-8 py-6 max-w-7xl mx-auto w-full">
  <div class="bg-white rounded-2xl border border-slate-200/80 p-6 shadow-sm flex flex-col md:flex-row items-center justify-between gap-8">
    
    <div class="flex flex-col text-center md:text-left shrink-0 max-w-xs">
      <p class="text-xs font-bold text-primary-orange uppercase tracking-widest mb-1">Organismes Agréés</p>
      <h3 class="text-lg font-extrabold font-display text-primary-navy leading-tight">
        Garantie d'État & Conformité Légale
      </h3>
    </div>

    <div class="grid lg:grid-cols-4 gap-4 w-full max-w-4xl items-center">
      
      <div class="bg-slate-50 border border-slate-100 rounded-xl p-4 flex flex-col items-center text-center group hover:bg-white hover:border-primary-orange/20 hover:shadow-sm transition-all duration-300">
        <div class="h-10 flex items-center justify-center font-black text-lg tracking-tighter text-[#0f2c59] select-none">
          QUALIBAT <span class="text-primary-orange ml-1">8711</span>
        </div>
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tight mt-2">Perméabilité à l'air</p>
      </div>

      <div class="bg-slate-50 border border-slate-100 rounded-xl p-4 flex flex-col items-center text-center group hover:bg-white hover:border-primary-orange/20 hover:shadow-sm transition-all duration-300">
        <div class="h-10 flex items-center justify-center font-black text-lg tracking-tighter text-[#0f2c59] select-none">
          QUALIBAT <span class="text-primary-orange ml-1">8721</span>
        </div>
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tight mt-2">Contrôle Ventilation VMC</p>
      </div>

      <div class="bg-slate-50 border border-slate-100 rounded-xl p-4 flex flex-col items-center text-center group hover:bg-white hover:border-primary-orange/20 hover:shadow-sm transition-all duration-300">
        <div class="h-10 flex items-center justify-center font-sans font-extrabold tracking-tight text-[#0f2c59] text-base select-none">
          ADEME
        </div>
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tight mt-2">Partenaire Transition</p>
      </div>

      <div class="bg-slate-50 border border-slate-100 rounded-xl p-4 flex flex-col items-center text-center group hover:bg-white hover:border-primary-orange/20 hover:shadow-sm transition-all duration-300">
        <div class="h-10 flex items-center justify-center font-display font-black tracking-tight text-primary-navy text-sm select-none uppercase">
          ⚡ PROMEVENT
        </div>
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tight mt-2">Protocole National VMC</p>
      </div>

    </div>

  </div>
</section>